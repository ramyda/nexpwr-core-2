generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  passwordHash  String?
  role          String    @default("CLIENT")
  name          String?
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  clientId      String?
  client        Client?   @relation(fields: [clientId], references: [id])
}

model Invite {
  id        String   @id @default(uuid())
  token     String   @unique
  email     String?
  role      String   @default("CLIENT")
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  clientId  String?
  client    Client?  @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model Client {
  id          String       @id @default(uuid())
  name        String
  company     String
  email       String       @unique
  phone       String?
  address     String?
  notes       String?
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  plan        String       @default("Pro")
  annotations        Annotation[]
  inspections        Inspection[]
  invites            Invite[]
  reports            Report[]
  sites              Site[]
  users              User[]
  thermographySites  ThermographySite[]
  clientNotes        Json?
}

model Site {
  id                        String       @id @default(uuid())
  clientId                  String?
  name                      String
  location                  String
  capacityMw                Float
  modules                   Int?
  inverter                  String?
  mountType                 String?
  ppaRate                   Float?
  performanceRatio          Float?
  moduleMakeModel           String?
  moduleManufacturer        String?
  moduleModel               String?
  moduleStcPower            Float?
  moduleTech                String?
  tempCoeffPmax             Float?
  noct                      Float?
  modulesPerString          Int?
  annualPoa                 Float?
  latitude                  Float?
  longitude                 Float?
  commissioningDate         DateTime?
  siteOwner                 String?
  omContractor              String?
  gridConnectionType        String?
  currency                  String       @default("USD")
  capacityAcMw              Float?
  inverterCount             Int?
  stringCount               Int?
  combinerBoxCount          Int?
  cellCount                 Int?
  moduleEfficiency          Float?
  moduleLength              Float?
  moduleWidth               Float?
  moduleHeight              Float?
  moduleWeight              Float?
  tempCoeffIsc              Float?
  tempCoeffVoc              Float?
  bifacialityFactor         Float?
  panFileUrl                String?
  inverterManufacturer      String?
  inverterModel             String?
  inverterType              String?
  inverterRatedPowerAc      Float?
  mpptCount                 Int?
  maxDcInputVoltage         Float?
  mpptVoltageMin            Float?
  mpptVoltageMax            Float?
  ratedAcOutputVoltage      Float?
  inverterEfficiency        Float?
  communicationProtocol     String?
  tiltAngle                 Float?
  azimuthAngle              Float?
  trackerMakeModel          String?
  rowSpacing                Float?
  dcCableSection            Float?
  acCableSection            Float?
  earthingSystem            String?
  lightningProtection       Boolean      @default(false)
  surgeProtection           Boolean      @default(false)
  availabilityTarget        Float?
  degradationRate           Float?
  ppaTerm                   Int?
  fitRate                   Float?
  minIrradianceThermography Float?       @default(600)
  minDeltaTThreshold        Float?       @default(3)
  cameraEmissivity          Float?       @default(0.85)
  preInspectionRunDuration  Int?         @default(60)
  thermalCameraModel        String?
  dronePlatform             String?
  isActive                  Boolean      @default(true)
  createdAt                 DateTime     @default(now())
  updatedAt                 DateTime     @updatedAt
  geofencePolygon           Json?
  annotations               Annotation[]
  inspections               Inspection[]
  reports                   Report[]
  client                    Client?      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  metrics                   SiteMetric[]
}

model Inspection {
  id                String       @id @default(uuid())
  siteId            String
  clientId          String?
  date              DateTime
  operator          String?
  droneModel        String?
  thermalSensor     String?
  ambientTempC      Float?
  humidityPercent   Float?
  windSpeedMs       Float?
  cloudCover        Float?
  irradianceWm2     Float?
  moduleTempC       Float?
  emissivity        Float?
  deltaTThreshold   Float?
  annualPoa         Float?
  ppaRate           Float?
  thermalFilePath   String?
  visualFilePath    String?
  status            String       @default("DRAFT")
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  thermalPreviewUrl String?
  annotations       Annotation[]
  client            Client?      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  site              Site         @relation(fields: [siteId], references: [id], onDelete: Cascade)
  reports           Report[]
  metrics           SiteMetric[]
}

model Annotation {
  id              String     @id @default(uuid())
  inspectionId    String
  clientId        String?
  siteId          String?
  type            String
  iecClass        String
  deltaT          Float
  tAnomaly        Float
  tReference      Float
  locationString  String?
  priority        String?
  modulesAffected Int        @default(1)
  notes           String?
  lat             Float?
  lng             Float?
  polygonPoints   Json?
  pixelCount      Int?
  status          String     @default("OPEN")
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  calculatedAt    DateTime?
  lossResults     Json?
  client          Client?    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  inspection      Inspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)
  site            Site?      @relation(fields: [siteId], references: [id], onDelete: Cascade)
}

/// Rolled-up site-level metrics per inspection — updated by the calculation engine
model SiteMetric {
  id                  String     @id @default(uuid())
  siteId              String
  inspectionId        String
  totalPowerLossKwp   Float      @default(0)
  totalRevenueLoss    Float      @default(0)
  totalAnomalyCount   Int        @default(0)
  criticalCount       Int        @default(0)
  moderateCount       Int        @default(0)
  minorCount          Int        @default(0)
  notSignificantCount Int        @default(0)
  pendingCount        Int        @default(0)
  resolvedCount       Int        @default(0)
  inProgressCount     Int        @default(0)
  falsePositiveCount  Int        @default(0)
  notFoundCount       Int        @default(0)
  iecClassA           Int        @default(0)
  iecClassB           Int        @default(0)
  iecClassC           Int        @default(0)
  iecClassD           Int        @default(0)
  calculatedAt        DateTime   @default(now())
  updatedAt           DateTime   @updatedAt
  inspection          Inspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)
  site                Site       @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([siteId, inspectionId])
}

model Report {
  id                String     @id @default(uuid())
  inspectionId      String
  clientId          String?
  siteId            String?
  status            String     @default("GENERATING")
  pdfUrl            String?
  csvUrl            String?
  kmlUrl            String?
  title             String?
  mapPngUrl         String?
  generatedAt       DateTime?
  publishedAt       DateTime?
  published         Boolean    @default(false)
  clientViewToken   String?    @unique @default(uuid())
  publishedToClient Boolean    @default(false)
  createdAt         DateTime   @default(now())
  client            Client?    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  inspection        Inspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)
  site              Site?      @relation(fields: [siteId], references: [id], onDelete: Cascade)
}

model Setting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

// =============================================================
// THERMOGRAPHY ENGINE MODELS
// =============================================================

model ThermographySite {
  id               String                  @id @default(uuid())
  name             String
  clientId         String?
  projectCode      String?
  latitude         Float?
  longitude        Float?
  acCapacity       Float?
  dcCapacity       Float?
  acUnit           String                  @default("MW")
  dcUnit           String                  @default("MW")
  moduleType       String?
  mountType        String?
  commissionedDate DateTime?
  landAreaAcres    Float?
  address          String?
  country          String?
  state            String?
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  inspections      ThermographyInspection[]
  audits           ThermographyAudit[]
  client           Client?                 @relation(fields: [clientId], references: [id])
}

model ThermographyInspection {
  id                  String                @id @default(uuid())
  siteId              String
  name                String
  inspectionYear      Int
  linkedClientAuditId String?
  createdAt           DateTime              @default(now())
  site                ThermographySite      @relation(fields: [siteId], references: [id], onDelete: Cascade)
  missions            ThermographyMission[]
}

model ThermographyMission {
  id                  String                   @id @default(uuid())
  inspectionId        String
  name                String
  blockName           String?
  imageCount          Int                      @default(0)
  annotatedImageCount Int                      @default(0)
  s3Id                String?
  status              String                   @default("active")
  orthoStatus         String                   @default("none")
  orthoTilesPath      String?
  orthoTifUrl         String?
  layoutGeoJson       String?
  createdAt           DateTime                 @default(now())
  inspection          ThermographyInspection   @relation(fields: [inspectionId], references: [id], onDelete: Cascade)
  images              ThermalImage[]
  annotations         ThermalAnnotation[]      @relation("MissionAnnotations")
}

model ThermalImage {
  id               String              @id @default(uuid())
  missionId        String
  filename         String
  s3Url            String?
  reviewed         Boolean             @default(false)
  isFaulty         Boolean             @default(false)
  annotationsCount Int                 @default(0)
  mission          ThermographyMission @relation(fields: [missionId], references: [id], onDelete: Cascade)
  annotations      ThermalAnnotation[] @relation("ImageAnnotations")
}

model ThermalAnnotation {
  id              String               @id @default(uuid())
  imageId         String?
  x               Float
  y               Float
  width           Float
  height          Float
  faultType       String?
  rackId          String?
  panelId         String?
  moduleTemp      Float?
  hotspotTemp     Float?
  deltaT          Float?
  severity        String               @default("Low")
  orthoAnnotation Boolean              @default(false)
  panelPolygonId  String?
  latitude        Float?
  longitude       Float?
  missionId       String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  image           ThermalImage?        @relation("ImageAnnotations", fields: [imageId], references: [id], onDelete: Cascade)
  mission         ThermographyMission? @relation("MissionAnnotations", fields: [missionId], references: [id], onDelete: Cascade)
}

model ThermographyAudit {
  id                    String            @id @default(uuid())
  siteId                String?
  name                  String
  groupId               String?
  startedAt             DateTime?
  completedAt           DateTime?
  status                String            @default("not_started")
  totalModulesInspected Int               @default(0)
  createdAt             DateTime          @default(now())
  site                  ThermographySite? @relation(fields: [siteId], references: [id])
}

model SummaryJob {
  id        String   @id @default(uuid())
  startedAt DateTime @default(now())
  timeTaken Int?
  status    String   @default("not_started")
}
