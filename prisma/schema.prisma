// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id             String    @id @default(uuid())
  email          String    @unique
  passwordHash   String?
  role           String    @default("CLIENT") // ADMIN or CLIENT
  name           String?
  emailVerified  DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model Invite {
  id        String   @id @default(uuid())
  token     String   @unique
  email     String?  // Optional: locked to specific email
  role      String   @default("CLIENT")
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Client {
  id             String    @id @default(uuid())
  name           String
  company        String
  email          String    @unique
  phone          String?
  address        String?
  notes          String?
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  sites          Site[]
  inspections    Inspection[]
  annotations    Annotation[]
  reports        Report[]
}

model Site {
  id               String       @id @default(uuid())
  clientId         String?
  client           Client?      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name             String
  location         String
  capacityMw       Float
  modules          Int?
  inverter         String?
  mountType        String?
  ppaRate          Float?
  performanceRatio Float?
  moduleMakeModel  String? // Deprecated: Use manufacturer/model fields instead
  moduleManufacturer String?
  moduleModel      String?
  moduleStcPower   Float?
  moduleTech       String?
  tempCoeffPmax    Float?
  noct             Float?
  modulesPerString Int?
  annualPoa        Float?
  
  // Site Identification
  latitude         Float?
  longitude        Float?
  commissioningDate DateTime?
  siteOwner        String?
  omContractor     String?
  gridConnectionType String?
  currency         String @default("USD")

  // Plant Capacity
  capacityAcMw     Float?
  inverterCount    Int?
  stringCount      Int?
  combinerBoxCount Int?

  // Module Specs (Extended)
  cellCount        Int?
  moduleEfficiency Float?
  moduleLength     Float?
  moduleWidth      Float?
  moduleHeight     Float?
  moduleWeight     Float?
  tempCoeffIsc     Float?
  tempCoeffVoc     Float?
  bifacialityFactor Float?
  panFileUrl       String?

  // Inverter Specs
  inverterManufacturer String?
  inverterModel    String?
  inverterType     String?
  inverterRatedPowerAc Float?
  mpptCount        Int?
  maxDcInputVoltage Float?
  mpptVoltageMin   Float?
  mpptVoltageMax   Float?
  ratedAcOutputVoltage Float?
  inverterEfficiency Float?
  communicationProtocol String?

  // Mounting & Electrical
  tiltAngle        Float?
  azimuthAngle     Float?
  trackerMakeModel String?
  rowSpacing       Float?
  dcCableSection   Float?
  acCableSection   Float?
  earthingSystem   String?
  lightningProtection Boolean @default(false)
  surgeProtection  Boolean @default(false)

  // Performance & Financial
  availabilityTarget Float?
  degradationRate   Float?
  ppaTerm           Int?
  fitRate           Float?

  // Inspection Parameters (Defaults)
  minIrradianceThermography Float? @default(600)
  minDeltaTThreshold Float? @default(3)
  cameraEmissivity Float? @default(0.85)
  preInspectionRunDuration Int? @default(60)
  thermalCameraModel String?
  dronePlatform    String?

  isActive         Boolean      @default(true)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  inspections      Inspection[]
  annotations      Annotation[]
  reports          Report[]
}

model Inspection {
  id               String     @id @default(uuid())
  siteId           String
  site             Site       @relation(fields: [siteId], references: [id], onDelete: Cascade)
  clientId         String?
  client           Client?      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  date             DateTime
  operator         String?
  droneModel       String?
  thermalSensor    String?
  ambientTempC     Float?
  humidityPercent  Float?
  windSpeedMs      Float?
  cloudCover       Float?
  irradianceWm2    Float?
  moduleTempC      Float?
  emissivity       Float?
  deltaTThreshold  Float?
  annualPoa        Float?
  ppaRate          Float?
  
  // File Storage
  thermalFilePath  String?
  visualFilePath   String?
  thermalPreviewUrl String?
  
  status           String     @default("DRAFT") // DRAFT, UPLOADED, IN_PROGRESS, COMPLETE, PUBLISHED
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  annotations      Annotation[]
  reports          Report[]
}

model Annotation {
  id               String     @id @default(uuid())
  inspectionId     String
  inspection       Inspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)
  clientId         String?
  client           Client?    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  siteId           String?
  site             Site?      @relation(fields: [siteId], references: [id], onDelete: Cascade)
  
  type             String
  iecClass         String
  deltaT           Float
  tAnomaly         Float
  tReference       Float
  locationString   String?
  priority         String?
  modulesAffected  Int        @default(1)
  notes            String?
  lat              Float?
  lng              Float?
  polygonPoints    Json?      // Storing as JSON
  pixelCount       Int?
  status           String     @default("OPEN") // OPEN, RESOLVED
  
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
}

model Report {
  id                String     @id @default(uuid())
  inspectionId      String
  inspection        Inspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)
  clientId          String?
  client            Client?    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  siteId            String?
  site             Site?      @relation(fields: [siteId], references: [id], onDelete: Cascade)
  
  status            String     @default("GENERATING") // GENERATING, READY
  pdfUrl            String?
  csvUrl            String?
  kmlUrl            String?
  mapPngUrl         String?
  
  generatedAt       DateTime?
  publishedAt       DateTime?
  publishedToClient Boolean    @default(false)
  
  createdAt         DateTime   @default(now())
}
model Setting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}
